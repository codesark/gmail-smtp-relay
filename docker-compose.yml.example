services:
  gmail-smtp-relay:
    image: codesark/gmail-smtp-relay:latest
    container_name: gmail-smtp-relay
    restart: unless-stopped
    env_file: .env
    ports:
      - "465:465"
      - "587:587"
    volumes:
      - ./data:/app/data
      - ./certs:/certs:ro
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:8080/healthz"]
      interval: 30s
      timeout: 5s
      retries: 5
