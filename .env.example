# SMTP Configuration
SMTP_BIND_ADDR_465=:465
SMTP_BIND_ADDR_587=:587
SMTP_REQUIRE_TLS_587=true
SMTP_HOSTNAME=smtp.yourdomain.com
SMTP_AUTH_USERS_JSON=[{"username":"user","password":"password"}]
ALLOWED_SENDER_REGEX=.*

# Gmail OAuth2 Configuration
GMAIL_CLIENT_ID=your-client-id
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token
GMAIL_OAUTH_REDIRECT_URI=http://localhost:8080
GMAIL_MAILBOX=your-email@gmail.com

# Persistence & Queuing
QUEUE_DB_PATH=./data/queue.db
QUEUE_MAX_BACKLOG=10000

# Worker Settings
WORKER_POLL_INTERVAL_SECONDS=1
WORKER_CONCURRENCY=4
WORKER_MAX_ATTEMPTS=8
WORKER_RETRY_BASE_SECONDS=5
WORKER_RETRY_MAX_SECONDS=300
SENDAS_REFRESH_SECONDS=300

# Observability
OBS_HTTP_ADDR=127.0.0.1:8080
LOG_LEVEL=info

# TLS Configuration
TLS_CERT_FILE=/certs/fullchain.pem
TLS_KEY_FILE=/certs/privkey.pem

# DNS & ACME (Used by deployment scripts)
ENABLE_AUTO_DNS=true
CF_API_TOKEN=your-cloudflare-token
CF_ZONE_ID=your-zone-id
CF_ZONE_NAME=yourdomain.com
DNS_NAME=smtp.yourdomain.com
LETSENCRYPT_EMAIL=admin@yourdomain.com
CERT_NAME=smtp.yourdomain.com
